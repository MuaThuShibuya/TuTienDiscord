# ================================================================
# .env.example — Vạn Pháp Tiên Nghịch Discord Bot v0.1.2
# Sao chép file này thành .env để chạy local.
# TUYỆT ĐỐI KHÔNG commit file .env thật lên git.
# ================================================================

# --- Ứng dụng ---
APP_ENV=development
APP_NAME=tu-tien-discord-bot
APP_VERSION=0.1.2

# --- HTTP Server ---
PORT=8080

# --- Discord ---
# Lấy từ https://discord.com/developers/applications
# DISCORD_APP_ID KHÔNG cần thiết — bot tự lấy từ Discord khi kết nối (Ready event).

DISCORD_TOKEN=

# Nhiều Guild ID phân cách bằng dấu phẩy (bắt buộc khi COMMAND_REGISTER_MODE=guild)
# Ví dụ: DISCORD_GUILD_IDS=123456789012345678,987654321098765432
DISCORD_GUILD_IDS=

# Nhiều Owner ID phân cách bằng dấu phẩy (admin bot — dùng cho lệnh quản trị sau này)
# Ví dụ: DISCORD_OWNER_IDS=111111111111111111,222222222222222222
DISCORD_OWNER_IDS=

# Chế độ đăng ký lệnh:
# "guild"  — hiệu lực tức thì, dùng cho development (cần DISCORD_GUILD_IDS)
# "global" — cần đến 1 giờ để propagate, dùng khi production đã ổn định
COMMAND_REGISTER_MODE=guild

# --- MongoDB Atlas ---
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<name>
# QUAN TRỌNG: Dùng database riêng cho bot này — không dùng chung với bot Casino hay app khác!
# Database sẽ được tạo tự động nếu chưa có.
MONGODB_URI=
MONGODB_DATABASE=tu_tien_bot

# --- Menu ---
# Thời gian tồn tại phiên menu (phút). Phiên hết hạn → user phải gọi /menu lại.
MENU_SESSION_TTL_MINUTES=15

# --- Logging ---
# LOG_LEVEL  : debug | info | warn | error
# LOG_FORMAT : console (đẹp khi local) | json (production/Render/VPS/Docker)
# LOG_COLOR  : true = ANSI color (chỉ dùng khi LOG_FORMAT=console và terminal hỗ trợ màu)
# LOG_CALLER : true = in file:dòng vào mỗi log (hữu ích khi debug, tắt ở production)
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_COLOR=true
LOG_CALLER=false

# --- Keepalive (chỉ cần khi deploy trên Render free tier) ---
# Bot tự ping /health để tránh service bị sleep sau 15 phút không có traffic.
# Trên VPS/Docker có process manager, đặt KEEPALIVE_ENABLED=false.
# KEEPALIVE_URL: để trống → tự ping localhost:<PORT>/health
# Ví dụ: KEEPALIVE_URL=https://ten-app.onrender.com/health
KEEPALIVE_ENABLED=false
KEEPALIVE_URL=
KEEPALIVE_INTERVAL_SECONDS=600
