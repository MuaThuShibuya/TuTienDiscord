# =============================================================
# .env.example — Tu Tien Discord Bot v0.1
# Copy this file to .env for local development.
# NEVER commit .env with real secrets to version control.
# =============================================================

# Application
APP_ENV=development
APP_NAME=tu-tien-discord-bot
APP_VERSION=0.1.0

# HTTP Server
PORT=8080

# Discord — required
# Get from https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DISCORD_OWNER_ID=

# Command registration mode:
# "guild"  — instant update, for development (requires DISCORD_GUILD_ID)
# "global" — up to 1h propagation, for production
COMMAND_REGISTER_MODE=guild

# MongoDB Atlas — required
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=
MONGODB_DATABASE=tu_tien_bot

# Menu session TTL in minutes (how long before inactive menu expires)
MENU_SESSION_TTL_MINUTES=15

# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# Keepalive (for Render free tier — self-pings /health to prevent sleep)
KEEPALIVE_ENABLED=false
KEEPALIVE_URL=
# Set KEEPALIVE_URL to your Render service URL, e.g.:
# KEEPALIVE_URL=https://your-app-name.onrender.com/health
